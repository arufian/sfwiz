# sfwiz environment variables
# Copy to .env and fill in values

# Required: Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional: override default model per persona
# SFWIZ_MODEL_DESIGNER=claude-opus-4-7
# SFWIZ_MODEL_DEVELOPER=claude-sonnet-4-6
# SFWIZ_MODEL_REVIEWER=claude-opus-4-7
# SFWIZ_MODEL_QA=claude-sonnet-4-6
# SFWIZ_MODEL_DEPLOY=claude-sonnet-4-6

# Optional: disable continuous-learn background worker
# SFWIZ_LEARN_DISABLED=true

# Optional: knowledge base directory (default: ~/.sfwiz/knowledge)
# SFWIZ_KNOWLEDGE_DIR=~/.sfwiz/knowledge
